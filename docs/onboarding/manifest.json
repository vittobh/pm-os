{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "pm-os-onboarding-tab",
  "packageName": "com.vittobh.pmos.onboarding",
  "developer": {
    "name": "Vittobha Vignesh S",
    "websiteUrl": "https://vittobh.github.io/pm-os",
    "privacyUrl": "https://vittobh.github.io/pm-os/onboarding/",
    "termsOfUseUrl": "https://vittobh.github.io/pm-os/onboarding/"
  },
  "name": { "short": "pm-os", "full": "pm-os: AI-Native PM Platform" },
  "description": {
    "short": "Your AI-native PM operating system",
    "full": "pm-os helps product managers discover, reuse, and generate PM artifacts across the full lifecycle. Connects Jira, Confluence, SharePoint, Yammer, Google Workspace, and PowerBI."
  },
  "icons": { "color": "icon-color.png", "outline": "icon-outline.png" },
  "accentColor": "#2563EB",
  "staticTabs": [
    {
      "entityId": "onboarding",
      "name": "Get Started",
      "contentUrl": "https://vittobh.github.io/pm-os/onboarding/teams.html",
      "websiteUrl": "https://vittobh.github.io/pm-os/onboarding/",
      "scopes": ["personal", "team"]
    },
    {
      "entityId": "cucp-deck",
      "name": "CuCP Rollout",
      "contentUrl": "https://vittobh.github.io/pm-os/cucp/presentation.html",
      "websiteUrl": "https://vittobh.github.io/pm-os/cucp/presentation.html",
      "scopes": ["personal", "team"]
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "https://vittobh.github.io/pm-os/onboarding/teams.html?config=1",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupChat"],
      "supportedSharePointHosts": ["sharePointFullPage", "sharePointWebPart"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["vittobh.github.io"]
}